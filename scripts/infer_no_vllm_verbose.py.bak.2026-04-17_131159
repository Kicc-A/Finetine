import os
import json
import time
import argparse
import torch
from transformers import AutoTokenizer, AutoModelForCausalLM
from tqdm import tqdm

def log(msg):
    print(f"[{time.strftime('%F %T')}] {msg}", flush=True)

def load_ckpt_state(path):
    ckpt = torch.load(path, map_location="cpu", weights_only=False)
    if isinstance(ckpt, dict):
        if "model" in ckpt and isinstance(ckpt["model"], dict):
            return ckpt["model"]
        return ckpt
    raise ValueError("Unsupported checkpoint format")

def read_jsonl(path, n=-1):
    data = []
    with open(path, "r", encoding="utf-8") as f:
        for i, line in enumerate(f):
            if n > 0 and i >= n:
                break
            line = line.strip()
            if line:
                data.append(json.loads(line))
    return data

def pick_keys(sample):
    if "input" in sample and "output" in sample:
        return "input", "output"
    if "problem" in sample and "answer" in sample:
        return "problem", "answer"
    raise ValueError(f"Unknown keys: {list(sample.keys())}")

def fmt_sec(sec):
    sec = max(0, int(sec))
    h = sec // 3600
    m = (sec % 3600) // 60
    s = sec % 60
    if h > 0:
        return f"{h}h{m}m{s}s"
    return f"{m}m{s}s"

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--base_model", required=True)
    ap.add_argument("--ckpt", required=True)
    ap.add_argument("--dataset", required=True)
    ap.add_argument("--save_path", required=True)
    ap.add_argument("--read_num", type=int, default=200)
    ap.add_argument("--max_new_tokens", type=int, default=256)
    args = ap.parse_args()

    log("Step 1/6: 准备设备")
    device = "cuda:0" if torch.cuda.is_available() else "cpu"  # #Edit
    log(f"device={device}, cuda_visible={os.getenv('CUDA_VISIBLE_DEVICES')}")

    log("Step 2/6: 加载 tokenizer")
    tok = AutoTokenizer.from_pretrained(args.base_model, trust_remote_code=True)

    log("Step 3/6: 加载基座模型")
    model = AutoModelForCausalLM.from_pretrained(
        args.base_model,
        dtype=torch.bfloat16 if torch.cuda.is_available() else torch.float32,  # #Edit
        trust_remote_code=True,
        device_map="auto",  # #Edit
        low_cpu_mem_usage=True  # #Edit
    ).eval()

    log("Step 4/6: 加载微调 checkpoint")
    state = load_ckpt_state(args.ckpt)
    missing, unexpected = model.load_state_dict(state, strict=False)
    log(f"checkpoint loaded: missing_keys={len(missing)}, unexpected_keys={len(unexpected)}")

    log("Step 5/6: 读取数据")
    data = read_jsonl(args.dataset, args.read_num)
    if not data:
        raise ValueError("Dataset is empty")
    in_key, out_key = pick_keys(data[0])
    total = len(data)
    log(f"dataset size={total}, keys=({in_key}, {out_key})")

    os.makedirs(os.path.dirname(args.save_path), exist_ok=True)
    log("Step 6/6: 开始推理并写结果")

    t0 = time.time()  # #Edit
    with open(args.save_path, "w", encoding="utf-8") as w:
        for idx, x in enumerate(tqdm(data, desc="Infer", ncols=100), start=1):
            prompt = f"Question:\n{x[in_key]}\n\nAnswer:"
            inputs = tok(prompt, return_tensors="pt").to(device)
            with torch.no_grad():
                out = model.generate(
                    **inputs,
                    max_new_tokens=args.max_new_tokens,
                    do_sample=False
                )
            pred = tok.decode(out[0][inputs["input_ids"].shape[1]:], skip_special_tokens=True)
            rec = {"question": x[in_key], "gold": x[out_key], "pred": pred}
            w.write(json.dumps(rec, ensure_ascii=False) + "\n")

            if idx % 10 == 0 or idx == total:  # #Edit
                elapsed = time.time() - t0
                avg = elapsed / idx
                eta = avg * (total - idx)
                log(f"Progress {idx}/{total} | avg={avg:.2f}s/item | ETA={fmt_sec(eta)}")  # #Edit

    log(f"完成，结果已保存到: {args.save_path}")

if __name__ == "__main__":
    main()
